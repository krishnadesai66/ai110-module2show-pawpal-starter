classDiagram
    %% PawPal+ — class diagram based on brainstormed design.
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +int minutesAvailable
        +str preferences
        +List~Pet~ pets
        +update() void
        +addPet(pet) void
    }

    class Pet {
        +str name
        +str animalType
        +str medication
        +str groomingType
        +str groomingFrequency
        +date groomingDate
        +update() void
    }

    class Frequency {
        <<enumeration>>
        ONE_TIME
        DAILY
        WEEKLY
    }

    class Task {
        +str taskId
        +str name
        +int duration
        +int priority
        +Pet pet
        +date dueDate
        +Frequency frequency
        +time startTime
        +bool completed
        +update() void
        +markComplete() void
        +occursOn(date) bool
    }

    class Schedule {
        +Owner owner
        +List~Task~ tasks
        +addTask(task) void
        +deleteTask(taskId) void
        +showTasks(date) List~Task~
        +tasksFor(pet) List~Task~
        +generateDailyPlan(date) List~Task~
        +explainPlan() str
    }

    Owner "1" --> "*" Pet : owns
    Schedule "1" --> "1" Owner : has
    Schedule "1" o-- "*" Task : contains
    Task "*" --> "1" Pet : for
    Task "*" --> "1" Frequency : repeats
