classDiagram
    %% PawPal+ — class diagram based on brainstormed design.
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +int minutesAvailable
        +str preferences
        +update() void
    }

    class Pet {
        +str name
        +str animalType
        +str medication
        +str groomingType
        +str groomingFrequency
        +date groomingDate
        +update() void
    }

    class Task {
        +str name
        +int duration
        +int priority
        +time startTime
        +update() void
    }

    class Schedule {
        +Owner owner
        +List~Task~ tasks
        +addTask(task) void
        +deleteTask(task) void
        +showTasks(date) List~Task~
        +generateDailyPlan(date) List~Task~
        +explainPlan() str
    }

    Owner "1" --> "1" Pet : owns
    Schedule "1" --> "1" Owner : has
    Schedule "1" o-- "*" Task : contains
